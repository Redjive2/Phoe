(goimport ('stdDependencies' dep))

(import 'std/core'
        'std/fmt')

(fun log! (String (spread Unknown)) None)
(let log! (caller (spread args)) = do
    (let data = (args.map
        &(fmt/format '<' it '>'))
    )
    (dep/DebugLog '[debug.Log @ ' caller '] ' '<n=' args.size '> : ' (spread data))
)

