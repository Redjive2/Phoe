(goimport ('stdDependencies' dep))
(import 'std/core')

(fun range (min max)
    (dep.RandomInt min max)
)

(fun float ()
    (dep.RandomFloat)
)

(fun shuffle (list) do
    (let var shuffled = [])
    (while (> list.size 0) then do
        (let var position = (range 0 list.size))
        (= shuffled (append shuffled list.[position]))
        (= list (list.[: position].concat list.[(+ position 1) :]))
    )
    shuffled
)