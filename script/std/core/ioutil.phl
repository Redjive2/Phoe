(import 'std/fmt'
        'std/pctl')

(fun print-line! ((spread Unknown)) None)
(let print-line! ((spread args)) =
    (pctl/stdout.write! (fmt/format (spread args) '\n'))
)

(fun print! ((spread Unknown)) None)
(let print! ((spread args)) =
    (pctl/stdout.write! (fmt/format (spread args)))
)

(fun read-line (String) String)
(let read-line (prompt) =
    (pctl/stdin.read-line prompt)
)
